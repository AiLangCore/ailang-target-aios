#!/bin/sh
set -eu

operation="${1:-}"
project="${2:-}"
shift 2 || true

target="aios-gui"
artifact_type="img"
out_dir="dist-aios"
target_version="0.0.1-alpha.5"
base_version="${AIOS_BASE_VERSION:-0.0.1-alpha.1}"
default_arch="x86_64"
case "$(uname -m 2>/dev/null || true)" in
  arm64|aarch64) default_arch="aarch64" ;;
esac
arch="${AIOS_ARCH:-$default_arch}"
splash_background=""
splash_foreground=""
boot_mode="qemu-kernel"
image_format="cpio.gz"
partition="none"
features=""
debug_console="${AIOS_DEBUG_CONSOLE:-none}"
framebuffer_trace="${AIOS_FRAMEBUFFER_TRACE:-0}"
event_loop_trace="${AIOS_EVENT_LOOP_TRACE:-0}"
evdev_trace="${AIOS_EVDEV_TRACE:-0}"
evdev_deep_trace="${AIOS_EVDEV_DEEP_TRACE:-0}"
runtime_log_level="${AIOS_RUNTIME_LOG_LEVEL:-}"
display_backend="${AIOS_DISPLAY_BACKEND:-auto}"
drm_trace="${AIOS_DRM_TRACE:-0}"
network_enabled=0
ca_bundle="${AIOS_CA_BUNDLE:-}"
serial_console="ttyS0"

apply_target_option() {
  assignment="$1"
  name="${assignment%%=*}"
  value="${assignment#*=}"
  if [ "$name" = "$assignment" ]; then
    echo "Err#err1(code=AIOS001 message=\"Invalid target option. Expected name=value: $assignment\" nodeId=aios)" >&2
    exit 2
  fi
  case "$name" in
    arch) arch="$value" ;;
    base-version) base_version="$value" ;;
    boot) boot_mode="$value" ;;
    image) image_format="$value" ;;
    partition) partition="$value" ;;
    feature) features="$features $value" ;;
    splash-background) splash_background="$value" ;;
    splash-foreground) splash_foreground="$value" ;;
    debug-console) debug_console="$value" ;;
    framebuffer-trace) framebuffer_trace="$value" ;;
    event-loop-trace) event_loop_trace="$value" ;;
    evdev-trace) evdev_trace="$value" ;;
    evdev-deep-trace) evdev_deep_trace="$value" ;;
    runtime-log-level) runtime_log_level="$value" ;;
    display-backend) display_backend="$value" ;;
    drm-trace) drm_trace="$value" ;;
    ca-bundle) ca_bundle="$value" ;;
    *)
      echo "Err#err1(code=AIOS001 message=\"Unsupported aios-gui target option: $name\" nodeId=aios)" >&2
      exit 2
      ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target)
      target="${2:-}"
      shift 2
      ;;
    --artifact-type|--type)
      artifact_type="${2:-}"
      shift 2
      ;;
    --target-version|--aios-version)
      target_version="${2:-}"
      shift 2
      ;;
    --base-version)
      base_version="${2:-}"
      shift 2
      ;;
    --base-version=*)
      base_version="${1#--base-version=}"
      shift
      ;;
    --arch)
      arch="${2:-}"
      shift 2
      ;;
    --arch=*)
      arch="${1#--arch=}"
      shift
      ;;
    --boot)
      boot_mode="${2:-}"
      shift 2
      ;;
    --boot=*)
      boot_mode="${1#--boot=}"
      shift
      ;;
    --image)
      image_format="${2:-}"
      shift 2
      ;;
    --image=*)
      image_format="${1#--image=}"
      shift
      ;;
    --partition)
      partition="${2:-}"
      shift 2
      ;;
    --partition=*)
      partition="${1#--partition=}"
      shift
      ;;
    --feature)
      features="$features ${2:-}"
      shift 2
      ;;
    --feature=*)
      features="$features ${1#--feature=}"
      shift
      ;;
    --out)
      out_dir="${2:-}"
      shift 2
      ;;
    --splash-background)
      splash_background="${2:-}"
      shift 2
      ;;
    --splash-background=*)
      splash_background="${1#--splash-background=}"
      shift
      ;;
    --splash-foreground)
      splash_foreground="${2:-}"
      shift 2
      ;;
    --splash-foreground=*)
      splash_foreground="${1#--splash-foreground=}"
      shift
      ;;
    --debug-console)
      debug_console="${2:-}"
      shift 2
      ;;
    --debug-console=*)
      debug_console="${1#--debug-console=}"
      shift
      ;;
    --ca-bundle)
      ca_bundle="${2:-}"
      shift 2
      ;;
    --ca-bundle=*)
      ca_bundle="${1#--ca-bundle=}"
      shift
      ;;
    --target-option)
      apply_target_option "${2:-}"
      shift 2
      ;;
    --target-option=*)
      apply_target_option "${1#--target-option=}"
      shift
      ;;
    --package-target)
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$operation" ] || [ -z "$project" ]; then
  echo 'Err#err1(code=AIOS001 message="target-aios-gui qemu runner requires operation and project." nodeId=aios)' >&2
  exit 2
fi

case "$artifact_type" in
  img|initramfs) ;;
  *)
    echo "Err#err1(code=AIOS001 message=\"aios-gui does not support artifact type: $artifact_type\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$arch" in
  x86_64)
    serial_console="ttyS0"
    ;;
  aarch64)
    serial_console="ttyAMA0"
    ;;
  *)
    echo "Err#err1(code=AIOS010 message=\"Unsupported AiOS architecture: $arch\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$boot_mode" in
  qemu-kernel) ;;
  disk|iso|uefi)
    echo "Err#err1(code=AIOS011 message=\"AiOS boot mode is declared but not implemented yet: $boot_mode\" nodeId=aios)" >&2
    exit 2
    ;;
  *)
    echo "Err#err1(code=AIOS011 message=\"Unsupported AiOS boot mode: $boot_mode\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$image_format" in
  cpio.gz) ;;
  ext4|squashfs|tar.gz|iso)
    echo "Err#err1(code=AIOS012 message=\"AiOS image format is declared but not implemented yet: $image_format\" nodeId=aios)" >&2
    exit 2
    ;;
  *)
    echo "Err#err1(code=AIOS012 message=\"Unsupported AiOS image format: $image_format\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$partition" in
  none) ;;
  mbr|gpt)
    echo "Err#err1(code=AIOS013 message=\"AiOS partition mode is declared but not implemented yet: $partition\" nodeId=aios)" >&2
    exit 2
    ;;
  *)
    echo "Err#err1(code=AIOS013 message=\"Unsupported AiOS partition mode: $partition\" nodeId=aios)" >&2
    exit 2
    ;;
esac

for feature in $features; do
  case "$feature" in
    network)
      network_enabled=1
      ;;
    printer|audio|wifi|bluetooth|gpu|storage)
      echo "Err#err1(code=AIOS014 message=\"AiOS feature is declared but not implemented yet: $feature\" nodeId=aios)" >&2
      exit 2
      ;;
    *)
      echo "Err#err1(code=AIOS014 message=\"Unsupported AiOS feature: $feature\" nodeId=aios)" >&2
      exit 2
      ;;
  esac
done

case "$debug_console" in
  none|stdio) ;;
  *)
    echo "Err#err1(code=AIOS016 message=\"Unsupported AiOS debug console: $debug_console\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$framebuffer_trace" in
  0|1|false|true) ;;
  *)
    echo "Err#err1(code=AIOS017 message=\"Unsupported AiOS framebuffer trace value: $framebuffer_trace\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$event_loop_trace" in
  0|1|false|true) ;;
  *)
    echo "Err#err1(code=AIOS019 message=\"Unsupported AiOS event loop trace value: $event_loop_trace\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$evdev_trace" in
  0|1|false|true) ;;
  *)
    echo "Err#err1(code=AIOS020 message=\"Unsupported AiOS evdev trace value: $evdev_trace\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$evdev_deep_trace" in
  0|1|false|true) ;;
  *)
    echo "Err#err1(code=AIOS021 message=\"Unsupported AiOS evdev deep trace value: $evdev_deep_trace\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$display_backend" in
  auto|framebuffer|drm) ;;
  *)
    echo "Err#err1(code=AIOS023 message=\"Unsupported AiOS display backend: $display_backend\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$drm_trace" in
  0|1|false|true) ;;
  *)
    echo "Err#err1(code=AIOS024 message=\"Unsupported AiOS DRM trace value: $drm_trace\" nodeId=aios)" >&2
    exit 2
    ;;
esac

if [ -n "$ca_bundle" ] && [ ! -f "$ca_bundle" ]; then
  echo "Err#err1(code=AIOS018 message=\"AiOS CA bundle does not exist: $ca_bundle\" nodeId=aios)" >&2
  exit 2
fi

ailang_bin="${AILANG_BIN:-ailang}"
cache_root="${AIOS_CACHE_ROOT:-${HOME:-.}/.ailang/cache/aios}"
base_dir="$cache_root/base/$target/$base_version/$arch"
base_manifest="$base_dir/manifest.toml"
base_kernel="$base_dir/bzImage"
base_initramfs="$base_dir/rootfs.cpio.gz"
tmp_root=""
published_splash_background=""
published_splash_foreground=""

cleanup() {
  if [ -n "$tmp_root" ] && [ -d "$tmp_root" ]; then
    rm -rf "$tmp_root"
  fi
}
trap cleanup EXIT INT TERM

resolve_runtime_bin() {
  env_name="$1"
  default_name="$2"
  candidate="${3:-}"
  eval "env_value=\${$env_name:-}"
  if [ -n "$env_value" ] && [ -f "$env_value" ]; then
    printf '%s\n' "$env_value"
    return 0
  fi
  if [ -n "$candidate" ] && [ -f "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi
  if command -v "$default_name" >/dev/null 2>&1; then
    command -v "$default_name"
    return 0
  fi
  return 1
}

has_qemu_arg() {
  wanted="$1"
  shift
  for arg in "$@"; do
    if [ "$arg" = "$wanted" ]; then
      return 0
    fi
  done
  return 1
}

emit_launcher() {
  launcher="$1"
  cat > "$launcher" <<EOF
#!/bin/sh
mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
mkdir -p /run /tmp /opt/aios

if [ "$debug_console" = "stdio" ] && [ -c /dev/$serial_console ]; then
  exec >/dev/$serial_console 2>&1
  echo "AiOS launcher: stdio debug console attached"
fi

export AILANG_RUNTIME_TARGET="\${AILANG_RUNTIME_TARGET:-aios-gui}"
export AILANG_RUNTIME_PLATFORM="\${AILANG_RUNTIME_PLATFORM:-desktop}"
export AIOS_FEATURE_NETWORK="\${AIOS_FEATURE_NETWORK:-$network_enabled}"
export AILANG_FB_TRACE="\${AILANG_FB_TRACE:-$framebuffer_trace}"
export AILANG_EVENT_LOOP_TRACE="\${AILANG_EVENT_LOOP_TRACE:-$event_loop_trace}"
export AILANG_EVDEV_TRACE="\${AILANG_EVDEV_TRACE:-$evdev_trace}"
export AILANG_EVDEV_DEEP_TRACE="\${AILANG_EVDEV_DEEP_TRACE:-$evdev_deep_trace}"
if [ "$display_backend" = "auto" ]; then
  if [ -e /dev/dri/card0 ]; then
    export AILANG_AIOS_DISPLAY_BACKEND="\${AILANG_AIOS_DISPLAY_BACKEND:-drm}"
  else
    export AILANG_AIOS_DISPLAY_BACKEND="\${AILANG_AIOS_DISPLAY_BACKEND:-framebuffer}"
  fi
else
  export AILANG_AIOS_DISPLAY_BACKEND="\${AILANG_AIOS_DISPLAY_BACKEND:-$display_backend}"
fi
export AILANG_DRM_TRACE="\${AILANG_DRM_TRACE:-$drm_trace}"
echo "AiOS display backend requested: \$AILANG_AIOS_DISPLAY_BACKEND"
if [ -n "$runtime_log_level" ]; then
  export AIVM_LOG_LEVEL="\${AIVM_LOG_LEVEL:-$runtime_log_level}"
fi

if [ "\${AIOS_FEATURE_NETWORK:-0}" = "1" ]; then
  network_iface=""
  for candidate in eth0 ens3 enp0s1 enp0s2; do
    if [ -d "/sys/class/net/\$candidate" ]; then
      network_iface="\$candidate"
      break
    fi
  done
  if [ -z "\$network_iface" ]; then
    for candidate_path in /sys/class/net/*; do
      candidate="\${candidate_path##*/}"
      if [ "\$candidate" != "lo" ] && [ -d "\$candidate_path" ]; then
        network_iface="\$candidate"
        break
      fi
    done
  fi
  ip link set lo up 2>/dev/null || ifconfig lo up 2>/dev/null || true
  if [ -n "\$network_iface" ]; then
    echo "AiOS network: using interface \$network_iface"
    ip link set "\$network_iface" up 2>/dev/null || ifconfig "\$network_iface" up 2>/dev/null || true
    if [ -f /usr/share/udhcpc/default.script ]; then
      udhcpc -i "\$network_iface" -n -q -s /usr/share/udhcpc/default.script 2>/dev/null || true
    else
      udhcpc -i "\$network_iface" -n -q 2>/dev/null || true
    fi
  else
    echo "AiOS network warning: no non-loopback interface found" >&2
  fi
  if [ ! -s /etc/resolv.conf ]; then
    echo "nameserver 10.0.2.3" > /run/resolv.conf 2>/dev/null || true
    ln -sf /run/resolv.conf /etc/resolv.conf 2>/dev/null || cp /run/resolv.conf /etc/resolv.conf 2>/dev/null || true
  fi
fi

if [ -f "/etc/ssl/certs/ca-certificates.crt" ]; then
    echo "CA bundle found at /etc/ssl/certs/ca-certificates.crt"
    export SSL_CERT_FILE="/etc/ssl/certs/ca-certificates.crt"
else
    echo "CA bundle not found."
fi

if [ -x /opt/aios/bin/aivectra ]; then
  /opt/aios/bin/aivectra run /opt/aios/app/app.aibc1
  echo "AiOS launch warning: AiVectra exited with status \$?" >&2
fi

if [ -x /opt/aios/bin/aivm ]; then
  /opt/aios/bin/aivm /opt/aios/app/app.aibc1
  echo "AiOS launch warning: AiVM exited with status \$?" >&2
fi

echo "AiOS launch stopped. Dropping to shell for diagnostics." >&2
exec sh
EOF
  chmod +x "$launcher"
}

resolve_ca_bundle() {
  if [ -n "$ca_bundle" ] && [ -f "$ca_bundle" ]; then
    printf '%s\n' "$ca_bundle"
    return 0
  fi
  for candidate in \
    /etc/ssl/cert.pem \
    /etc/ssl/certs/ca-certificates.crt \
    /opt/homebrew/etc/openssl@3/cert.pem \
    /usr/local/etc/openssl@3/cert.pem \
    /usr/local/share/ca-certificates/ca-bundle.crt \
    /etc/pki/tls/certs/ca-bundle.crt
  do
    if [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

inject_payload_initramfs() {
  runtime_aivm="$1"
  runtime_aivectra="$2"
  output_initramfs="$3"

  if ! command -v gzip >/dev/null 2>&1 || ! command -v cpio >/dev/null 2>&1; then
    echo 'Err#err1(code=AIOS007 message="AiOS payload injection requires gzip and cpio." nodeId=aios)' >&2
    exit 2
  fi

  tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/aios-rootfs-XXXXXX")"
  gzip -dc "$base_initramfs" | (cd "$tmp_root" && cpio -idmu >/dev/null 2>&1)

  runtime_info="$(file "$runtime_aivectra" 2>/dev/null || true)"
  if printf '%s\n' "$runtime_info" | grep -Fq '/lib64/ld-linux-x86-64.so.2' &&
     [ ! -f "$tmp_root/lib64/ld-linux-x86-64.so.2" ]; then
    echo 'Err#err1(code=AIOS015 message="AiOS base is missing glibc loader required by the Linux AiVectra runtime. Rebuild/import a glibc AiOS base." nodeId=aios)' >&2
    exit 2
  fi

  mkdir -p "$tmp_root/opt/aios/app" "$tmp_root/opt/aios/bin" "$tmp_root/opt/aios/etc"
  cp "$app_aibc1" "$tmp_root/opt/aios/app/app.aibc1"
  cp "$runtime_aivm" "$tmp_root/opt/aios/bin/aivm"
  cp "$runtime_aivectra" "$tmp_root/opt/aios/bin/aivectra"
  chmod +x "$tmp_root/opt/aios/bin/aivm" "$tmp_root/opt/aios/bin/aivectra"
  if [ "$network_enabled" = "1" ]; then
    resolved_ca_bundle="$(resolve_ca_bundle || true)"
    if [ -n "$resolved_ca_bundle" ]; then
      mkdir -p "$tmp_root/etc/ssl/certs" "$tmp_root/usr/lib/ssl"
      cp "$resolved_ca_bundle" "$tmp_root/etc/ssl/certs/ca-certificates.crt"
      ln -sf /etc/ssl/certs/ca-certificates.crt "$tmp_root/usr/lib/ssl/cert.pem"
    else
      echo 'Err#err1(code=AIOS018 message="AiOS network image requires a CA bundle for HTTPS, but none was found on the host system. Install a CA bundle (e.g., via Homebrew) or set AIOS_CA_BUNDLE to a valid path." nodeId=aios)' >&2
      exit 1
    fi
  fi
  image_splash_background=""
  image_splash_foreground=""
  if [ -n "$splash_background" ] && [ -f "$splash_background" ]; then
    mkdir -p "$tmp_root/opt/aios/splash"
    cp "$splash_background" "$tmp_root/opt/aios/splash/background.svg"
    image_splash_background="/opt/aios/splash/background.svg"
  fi
  if [ -n "$splash_foreground" ] && [ -f "$splash_foreground" ]; then
    mkdir -p "$tmp_root/opt/aios/splash"
    cp "$splash_foreground" "$tmp_root/opt/aios/splash/foreground.svg"
    image_splash_foreground="/opt/aios/splash/foreground.svg"
  fi
  emit_launcher "$tmp_root/opt/aios/bin/aios-launch"
  emit_launcher "$tmp_root/init"

  cat > "$tmp_root/opt/aios/etc/image.toml" <<EOF
schema = "ailang.aios.runtime-image.v1"
target = "$target"
aiosVersion = "$target_version"
arch = "$arch"
profile = "gui"
app = "/opt/aios/app/app.aibc1"
aivm = "/opt/aios/bin/aivm"
aivectra = "/opt/aios/bin/aivectra"
boot = "$boot_mode"
image = "$image_format"
partition = "$partition"
splashBackground = "$image_splash_background"
splashForeground = "$image_splash_foreground"
EOF

  (cd "$tmp_root" && find . | sort | cpio -o -H newc 2>/dev/null | gzip -n > "$output_initramfs")
}

if [ ! -f "$base_manifest" ] || [ ! -f "$base_kernel" ] || [ ! -f "$base_initramfs" ]; then
  echo "Err#err1(code=AIOS004 message=\"AiOS GUI base image is not built. Run on Linux: ailang aios build-base --target $target --version $base_version --arch $arch, or import an existing base with that version.\" nodeId=aios)" >&2
  exit 2
fi

mkdir -p "$out_dir"
out_dir="$(CDPATH= cd -- "$out_dir" && pwd)"

"$ailang_bin" build "$project" >/dev/null

app_aibc1="$project/app.aibc1"
if [ ! -f "$app_aibc1" ]; then
  echo 'Err#err1(code=AIOS002 message="aios-gui publish expected app.aibc1 after build." nodeId=aios)' >&2
  exit 2
fi

if [ -z "$splash_background" ] && [ -f "$project/src/Assets/Splash/background.svg" ]; then
  splash_background="$project/src/Assets/Splash/background.svg"
fi
if [ -z "$splash_foreground" ] && [ -f "$project/src/Assets/Splash/foreground.svg" ]; then
  splash_foreground="$project/src/Assets/Splash/foreground.svg"
fi

cp "$app_aibc1" "$out_dir/app.aibc1"
cp "$base_manifest" "$out_dir/base.manifest.toml"
cp "$base_kernel" "$out_dir/bzImage"
if [ -n "$splash_background" ]; then
  published_splash_background="rootfs:/opt/aios/splash/background.svg"
fi
if [ -n "$splash_foreground" ]; then
  published_splash_foreground="rootfs:/opt/aios/splash/foreground.svg"
fi

sdk_root="$(CDPATH= cd -- "$(dirname -- "$ailang_bin")/.." 2>/dev/null && pwd || true)"
default_aivm=""
default_aivectra=""
if [ "$arch" = "x86_64" ] && [ -n "$sdk_root" ] && [ -f "$sdk_root/.artifacts/ailang-linux-x64/aivm-runtime" ]; then
  default_aivm="$sdk_root/.artifacts/ailang-linux-x64/aivm-runtime"
elif [ "$arch" = "aarch64" ] && [ -n "$sdk_root" ] && [ -f "$sdk_root/.artifacts/ailang-linux-arm64/aivm-runtime" ]; then
  default_aivm="$sdk_root/.artifacts/ailang-linux-arm64/aivm-runtime"
fi
if [ "$arch" = "x86_64" ] && [ -n "$sdk_root" ] && [ -f "$sdk_root/runtimes/linux-x64/aivectra" ]; then
  default_aivectra="$sdk_root/runtimes/linux-x64/aivectra"
elif [ "$arch" = "aarch64" ] && [ -n "$sdk_root" ] && [ -f "$sdk_root/runtimes/linux-arm64/aivectra" ]; then
  default_aivectra="$sdk_root/runtimes/linux-arm64/aivectra"
fi
if [ -z "$default_aivm" ] && [ "$arch" = "x86_64" ] && [ -n "$sdk_root" ] && [ -f "$sdk_root/runtimes/linux-x64/aivm-runtime" ]; then
  default_aivm="$sdk_root/runtimes/linux-x64/aivm-runtime"
elif [ -z "$default_aivm" ] && [ "$arch" = "aarch64" ] && [ -n "$sdk_root" ] && [ -f "$sdk_root/runtimes/linux-arm64/aivm-runtime" ]; then
  default_aivm="$sdk_root/runtimes/linux-arm64/aivm-runtime"
fi

runtime_aivm="$(resolve_runtime_bin AIOS_AIVM_BIN aivm "$default_aivm" || true)"
runtime_aivectra="$(resolve_runtime_bin AIOS_AIVECTRA_BIN aivectra "$default_aivectra" || true)"
if [ -z "$runtime_aivm" ]; then
  echo "Err#err1(code=AIOS008 message=\"AiOS GUI image needs a Linux AiVM runtime. Set AIOS_AIVM_BIN or build SDK runtime artifacts for $arch.\" nodeId=aios)" >&2
  exit 2
fi
if [ -z "$runtime_aivectra" ]; then
  echo "Err#err1(code=AIOS009 message=\"AiOS GUI image needs a Linux AiVectra host. Expected SDK runtime slot runtimes/linux-x64/aivectra or runtimes/linux-arm64/aivectra, or set AIOS_AIVECTRA_BIN.\" nodeId=aios)" >&2
  exit 2
fi

inject_payload_initramfs "$runtime_aivm" "$runtime_aivectra" "$out_dir/rootfs.cpio.gz"

cat > "$out_dir/manifest.toml" <<EOF
schema = "ailang.aios.image.v1"
target = "$target"
aiosVersion = "$target_version"
baseVersion = "$base_version"
arch = "$arch"
profile = "gui"
artifactType = "$artifact_type"
boot = "$boot_mode"
image = "$image_format"
partition = "$partition"
app = "app.aibc1"
baseManifest = "base.manifest.toml"
kernel = "bzImage"
initramfs = "rootfs.cpio.gz"
aivm = "rootfs:/opt/aios/bin/aivm"
aivectra = "rootfs:/opt/aios/bin/aivectra"
splashBackground = "$published_splash_background"
splashForeground = "$published_splash_foreground"
debugConsole = "$debug_console"
framebufferTrace = "$framebuffer_trace"
eventLoopTrace = "$event_loop_trace"
evdevTrace = "$evdev_trace"
evdevDeepTrace = "$evdev_deep_trace"
displayBackend = "$display_backend"
drmTrace = "$drm_trace"
network = "$network_enabled"
EOF

if [ "$operation" = "run" ]; then
  debug_console_args=""
  network_args=""
  qemu_bin=""
  qemu_machine_args=""
  qemu_append_console=""
  case "$arch" in
    x86_64)
      qemu_bin="qemu-system-x86_64"
      qemu_append_console="console=tty0 console=ttyS0"
      if [ "$network_enabled" = "1" ] && ! has_qemu_arg "-netdev" "$@"; then
        network_args="-netdev user,id=aiosnet -device e1000,netdev=aiosnet"
      fi
      ;;
    aarch64)
      qemu_bin="qemu-system-aarch64"
      qemu_machine_args="-machine virt -cpu max"
      qemu_append_console="console=ttyAMA0"
      if [ "$network_enabled" = "1" ] && ! has_qemu_arg "-netdev" "$@"; then
        network_args="-netdev user,id=aiosnet -device virtio-net-device,netdev=aiosnet"
      fi
      ;;
  esac
  if ! command -v "$qemu_bin" >/dev/null 2>&1; then
    echo "Err#err1(code=AIOS022 message=\"Required QEMU runner is not installed for AiOS $arch: $qemu_bin\" nodeId=aios)" >&2
    exit 2
  fi
  if [ "$debug_console" = "stdio" ] && ! has_qemu_arg "-serial" "$@"; then
    debug_console_args="-serial stdio"
  fi
  if [ "$debug_console" = "stdio" ]; then
    echo "AiOS debug console: stdio serial enabled for $target $target_version" >&2
  fi
  # shellcheck disable=SC2086
  exec "$qemu_bin" \
    $qemu_machine_args \
    -kernel "$out_dir/bzImage" \
    -initrd "$out_dir/rootfs.cpio.gz" \
    -append "$qemu_append_console loglevel=3 vt.global_cursor_default=0 ailang.target=aios-gui ailang.app=app.aibc1" \
    $debug_console_args \
    $network_args \
    "$@"
fi

echo "Ok#ok1(type=string value=\"$out_dir\")"
