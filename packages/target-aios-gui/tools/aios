#!/bin/sh
set -eu

command="${1:-}"
shift || true

target="aios-gui"
version="0.0.1-alpha.4"
arch="${AIOS_ARCH:-x86_64}"
buildroot_version="${AIOS_BUILDROOT_VERSION:-2026.02.3}"
from_dir=""
boot_mode="qemu-kernel"
image_format="cpio.gz"
partition="none"
features=""

apply_target_option() {
  assignment="$1"
  name="${assignment%%=*}"
  value="${assignment#*=}"
  if [ "$name" = "$assignment" ]; then
    echo "Err#err1(code=AIOS001 message=\"Invalid target option. Expected name=value: $assignment\" nodeId=aios)" >&2
    exit 2
  fi
  case "$name" in
    arch) arch="$value" ;;
    boot) boot_mode="$value" ;;
    image) image_format="$value" ;;
    partition) partition="$value" ;;
    feature) features="$features $value" ;;
    *)
      echo "Err#err1(code=AIOS001 message=\"Unsupported aios target option: $name\" nodeId=aios)" >&2
      exit 2
      ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target)
      target="${2:-}"
      shift 2
      ;;
    --version|--target-version|--aios-version)
      version="${2:-}"
      shift 2
      ;;
    --arch)
      arch="${2:-}"
      shift 2
      ;;
    --arch=*)
      arch="${1#--arch=}"
      shift
      ;;
    --buildroot-version)
      buildroot_version="${2:-}"
      shift 2
      ;;
    --boot)
      boot_mode="${2:-}"
      shift 2
      ;;
    --boot=*)
      boot_mode="${1#--boot=}"
      shift
      ;;
    --image)
      image_format="${2:-}"
      shift 2
      ;;
    --image=*)
      image_format="${1#--image=}"
      shift
      ;;
    --partition)
      partition="${2:-}"
      shift 2
      ;;
    --partition=*)
      partition="${1#--partition=}"
      shift
      ;;
    --feature)
      features="$features ${2:-}"
      shift 2
      ;;
    --feature=*)
      features="$features ${1#--feature=}"
      shift
      ;;
    --target-option)
      apply_target_option "${2:-}"
      shift 2
      ;;
    --target-option=*)
      apply_target_option "${1#--target-option=}"
      shift
      ;;
    --from)
      from_dir="${2:-}"
      shift 2
      ;;
    *)
      echo "Err#err1(code=AIOS001 message=\"Unsupported aios option: $1\" nodeId=aios)" >&2
      exit 2
      ;;
  esac
done

case "$arch" in
  x86_64|aarch64) ;;
  *)
    echo "Err#err1(code=AIOS010 message=\"Unsupported AiOS architecture: $arch\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$boot_mode" in
  qemu-kernel) ;;
  disk|iso|uefi)
    echo "Err#err1(code=AIOS011 message=\"AiOS boot mode is declared but not implemented yet: $boot_mode\" nodeId=aios)" >&2
    exit 2
    ;;
  *)
    echo "Err#err1(code=AIOS011 message=\"Unsupported AiOS boot mode: $boot_mode\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$image_format" in
  cpio.gz) ;;
  ext4|squashfs|tar.gz|iso)
    echo "Err#err1(code=AIOS012 message=\"AiOS image format is declared but not implemented yet: $image_format\" nodeId=aios)" >&2
    exit 2
    ;;
  *)
    echo "Err#err1(code=AIOS012 message=\"Unsupported AiOS image format: $image_format\" nodeId=aios)" >&2
    exit 2
    ;;
esac

case "$partition" in
  none) ;;
  mbr|gpt)
    echo "Err#err1(code=AIOS013 message=\"AiOS partition mode is declared but not implemented yet: $partition\" nodeId=aios)" >&2
    exit 2
    ;;
  *)
    echo "Err#err1(code=AIOS013 message=\"Unsupported AiOS partition mode: $partition\" nodeId=aios)" >&2
    exit 2
    ;;
esac

for feature in $features; do
  case "$feature" in
    network)
      ;;
    printer|audio|wifi|bluetooth|gpu|storage)
      echo "Err#err1(code=AIOS014 message=\"AiOS feature is declared but not implemented yet: $feature\" nodeId=aios)" >&2
      exit 2
      ;;
    *)
      echo "Err#err1(code=AIOS014 message=\"Unsupported AiOS feature: $feature\" nodeId=aios)" >&2
      exit 2
      ;;
  esac
done

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
package_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
cache_root="${AIOS_CACHE_ROOT:-${HOME:-.}/.ailang/cache/aios}"
base_dir="$cache_root/base/$target/$version/$arch"
build_dir="$cache_root/buildroot-work/$target/$version/$arch"
buildroot_cache_dir="$cache_root/buildroot/$buildroot_version"

host_os() {
  uname -s 2>/dev/null || printf 'unknown\n'
}

make_cmd() {
  if [ -n "${AIOS_MAKE:-}" ]; then
    printf '%s\n' "$AIOS_MAKE"
  else
    printf '%s\n' "make"
  fi
}

host_cc() {
  if [ -n "${AIOS_HOST_CC:-}" ]; then
    printf '%s\n' "$AIOS_HOST_CC"
  elif command -v gcc >/dev/null 2>&1; then
    command -v gcc
  else
    printf '%s\n' ""
  fi
}

require_linux_build_host() {
  os=$(host_os)
  if [ "$os" != "Linux" ] && [ "${AIOS_ALLOW_UNSUPPORTED_HOST:-0}" != "1" ]; then
    echo "Err#err1(code=AIOS007 message=\"AiOS Buildroot base creation requires a Linux build host. This host is $os. Use CI/Linux to run build-base, then consume the cached base on macOS with run/publish.\" nodeId=aios)" >&2
    exit 2
  fi
}

hash_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    echo "unknown"
  fi
}

defconfig_for() {
  case "$target:$arch" in
    aios-gui:x86_64)
      printf '%s\n' "$package_root/buildroot/configs/aios_gui_x86_64_defconfig"
      ;;
    aios-gui:aarch64)
      printf '%s\n' "$package_root/buildroot/configs/aios_gui_aarch64_defconfig"
      ;;
    *)
      echo "Err#err1(code=AIOS001 message=\"No Buildroot defconfig for $target/$arch\" nodeId=aios)" >&2
      exit 2
      ;;
  esac
}

kernel_fragment_for() {
  case "$target:$arch" in
    aios-gui:x86_64)
      printf '%s\n' "$package_root/buildroot/kernel/aios_gui_x86_64.fragment"
      ;;
    aios-gui:aarch64)
      printf '%s\n' "$package_root/buildroot/kernel/aios_gui_aarch64.fragment"
      ;;
    *)
      echo "Err#err1(code=AIOS001 message=\"No AiOS kernel fragment for $target/$arch\" nodeId=aios)" >&2
      exit 2
      ;;
  esac
}

kernel_image_for() {
  case "$arch" in
    x86_64) printf '%s\n' "bzImage" ;;
    aarch64) printf '%s\n' "Image" ;;
  esac
}

case "$command" in
  list-base)
    if [ -d "$cache_root/base" ]; then
      find "$cache_root/base" -name manifest.toml -print | sort
    fi
    ;;

  base-dir)
    printf '%s\n' "$base_dir"
    ;;

  fetch-buildroot)
    mkdir -p "$cache_root/buildroot"
    if [ -d "$buildroot_cache_dir/.git" ]; then
      git -C "$buildroot_cache_dir" fetch --tags --quiet
      git -C "$buildroot_cache_dir" checkout --quiet "$buildroot_version"
    else
      git clone --depth 1 --branch "$buildroot_version" https://gitlab.com/buildroot.org/buildroot.git "$buildroot_cache_dir"
    fi
    echo "Ok#ok1(type=string value=\"$buildroot_cache_dir\")"
    ;;

  verify-base)
    if [ ! -f "$base_dir/manifest.toml" ] || [ ! -f "$base_dir/bzImage" ] || [ ! -f "$base_dir/rootfs.cpio.gz" ]; then
      echo "Err#err1(code=AIOS004 message=\"AiOS base is missing for $target $version $arch\" nodeId=aios)" >&2
      exit 2
    fi
    echo "Ok#ok1(type=string value=\"$base_dir\")"
    ;;

  import-base)
    if [ -z "$from_dir" ]; then
      echo 'Err#err1(code=AIOS001 message="import-base requires --from <artifact-directory>" nodeId=aios)' >&2
      exit 2
    fi
    if [ ! -f "$from_dir/manifest.toml" ] || [ ! -f "$from_dir/bzImage" ] || [ ! -f "$from_dir/rootfs.cpio.gz" ]; then
      echo "Err#err1(code=AIOS004 message=\"AiOS base artifact is missing manifest.toml, bzImage, or rootfs.cpio.gz: $from_dir\" nodeId=aios)" >&2
      exit 2
    fi
    mkdir -p "$base_dir"
    cp "$from_dir/manifest.toml" "$base_dir/manifest.toml"
    cp "$from_dir/bzImage" "$base_dir/bzImage"
    cp "$from_dir/rootfs.cpio.gz" "$base_dir/rootfs.cpio.gz"
    echo "Ok#ok1(type=string value=\"$base_dir\")"
    ;;

  build-base)
    require_linux_build_host
    buildroot_dir="${AIOS_BUILDROOT_DIR:-$buildroot_cache_dir}"
    if [ -z "$buildroot_dir" ] || [ ! -d "$buildroot_dir" ]; then
      echo "Err#err1(code=AIOS005 message=\"Buildroot checkout is missing. Run: ailang aios fetch-buildroot --buildroot-version $buildroot_version or set AIOS_BUILDROOT_DIR.\" nodeId=aios)" >&2
      exit 2
    fi
    make_bin=$(make_cmd)
    cc_bin=$(host_cc)
    if [ -z "$cc_bin" ]; then
      echo 'Err#err1(code=AIOS008 message="AiOS base creation requires a host C compiler. Install gcc on the Linux build host or set AIOS_HOST_CC." nodeId=aios)' >&2
      exit 2
    fi
    defconfig_template=$(defconfig_for)
    defconfig="$build_dir/aios.defconfig"
    kernel_fragment=$(kernel_fragment_for)
    kernel_image=$(kernel_image_for)
    if [ ! -f "$kernel_fragment" ]; then
      echo "Err#err1(code=AIOS006 message=\"AiOS kernel fragment is missing: $kernel_fragment\" nodeId=aios)" >&2
      exit 2
    fi
    mkdir -p "$build_dir" "$base_dir"
    sed \
      -e "s|@AIOS_ROOTFS_OVERLAY@|$package_root/buildroot/overlays/rootfs|g" \
      -e "s|@AIOS_KERNEL_FRAGMENT@|$kernel_fragment|g" \
      "$defconfig_template" > "$defconfig"
    "$make_bin" -C "$buildroot_dir" O="$build_dir" HOSTCC="$cc_bin" BR2_DEFCONFIG="$defconfig" defconfig
    "$make_bin" -C "$buildroot_dir" O="$build_dir" HOSTCC="$cc_bin"
    if [ ! -f "$build_dir/images/$kernel_image" ] || [ ! -f "$build_dir/images/rootfs.cpio.gz" ]; then
      echo "Err#err1(code=AIOS006 message=\"Buildroot completed without expected $kernel_image/rootfs.cpio.gz outputs.\" nodeId=aios)" >&2
      exit 2
    fi
    cp "$build_dir/images/$kernel_image" "$base_dir/bzImage"
    cp "$build_dir/images/rootfs.cpio.gz" "$base_dir/rootfs.cpio.gz"
    cat > "$base_dir/manifest.toml" <<EOF
schema = "ailang.aios.base.v1"
aiosVersion = "$version"
target = "$target"
arch = "$arch"
buildrootDir = "$buildroot_dir"
buildrootVersion = "$buildroot_version"
defconfig = "$defconfig"
kernelFragment = "$kernel_fragment"
libc = "glibc"
kernel = "bzImage"
kernelImage = "$kernel_image"
initramfs = "rootfs.cpio.gz"
kernelHash = "$(hash_file "$base_dir/bzImage")"
initramfsHash = "$(hash_file "$base_dir/rootfs.cpio.gz")"
aivmAbi = 1
EOF
    echo "Ok#ok1(type=string value=\"$base_dir\")"
    ;;

  *)
    echo 'Usage: ailang aios <fetch-buildroot|build-base|verify-base|import-base|list-base|base-dir> [--target aios-gui] [--version 0.0.1-alpha.4] [--arch x86_64|aarch64] [--buildroot-version 2026.02.3] [--from artifact-dir]' >&2
    exit 2
    ;;
esac
